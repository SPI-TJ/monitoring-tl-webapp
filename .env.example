# =============================================================================
# AUDIT MONITORING WEB APPLICATION - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy file ini menjadi .env dan isi dengan kredensial Anda
# JANGAN commit file .env ke Git!

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
# NODE_ENV options: development, production

# -----------------------------------------------------------------------------
# Google Sheets Configuration
# -----------------------------------------------------------------------------
# ID dari Google Spreadsheet Anda
# Cara mendapatkan: Buka spreadsheet, lihat URL
# https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
SPREADSHEET_ID=your-spreadsheet-id-here

# Email service account Google Cloud
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# -----------------------------------------------------------------------------
# Google Cloud Credentials
# -----------------------------------------------------------------------------
# OPTION 1: Path ke file JSON service account key (recommended untuk development)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account-key.json

# OPTION 2: Paste langsung JSON credentials (untuk deployment Heroku/Vercel)
# Uncomment dan paste JSON key di bawah (single line, escaped)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# -----------------------------------------------------------------------------
# Security (Optional - untuk production)
# -----------------------------------------------------------------------------
# Session secret untuk authentication
SESSION_SECRET=your-random-secret-key-here-change-this

# Allowed origins untuk CORS (comma separated)
# Development: http://localhost:3000
# Production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# API Rate Limiting (Optional)
# -----------------------------------------------------------------------------
# Max requests per 15 minutes per IP
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# -----------------------------------------------------------------------------
# Logging (Optional)
# -----------------------------------------------------------------------------
# Log level: error, warn, info, debug
LOG_LEVEL=info

# =============================================================================
# INSTRUCTIONS
# =============================================================================
# 
# 1. Setup Google Cloud Project:
#    - Buka https://console.cloud.google.com/
#    - Buat atau pilih project
#    - Enable Google Sheets API
#    - Buat Service Account
#    - Download JSON key file
#
# 2. Share Google Sheets:
#    - Buka spreadsheet Anda
#    - Click Share
#    - Tambahkan email service account dengan role "Editor"
#
# 3. Copy file ini:
#    cp .env.example .env
#
# 4. Edit .env dengan credentials Anda:
#    nano .env
#
# 5. Test configuration:
#    npm start
#
# =============================================================================
