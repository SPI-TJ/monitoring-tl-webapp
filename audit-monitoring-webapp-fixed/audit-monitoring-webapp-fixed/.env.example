# ─────────────────────────────────────────────────────────────
# AUDIT MONITORING WEBAPP — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy file ini menjadi .env dan isi nilainya.
# JANGAN pernah commit file .env ke Git!

# ── Google Sheets ────────────────────────────────────────────
# ID spreadsheet: ambil dari URL
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Service Account credentials (dari file JSON yang didownload di Google Cloud)
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private key: copy dari JSON, termasuk -----BEGIN ... END-----
# Ganti newline dengan \n agar bisa dimasukkan ke .env
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----\n"

# ── JWT ──────────────────────────────────────────────────────
# Ganti dengan random string panjang (min 32 karakter)
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti_dengan_random_string_sangat_panjang_dan_aman_min_32_chars

# ── App ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
